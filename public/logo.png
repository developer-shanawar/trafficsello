<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="100%" height="100%">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0B0F19" />
      <stop offset="100%" stop-color="#111827" />
    </linearGradient>
    <linearGradient id="neonGrad" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00F0FF" />
      <stop offset="50%" stop-color="#DFFF2F" />
      <stop offset="100%" stop-color="#E2FF45" />
    </linearGradient>
    <linearGradient id="arrowGrad" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00E5FF" />
      <stop offset="100%" stop-color="#DFFF2F" />
    </linearGradient>
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <stop offset="0%" stop-color="#DFFF2F" stop-opacity="0.4" />
      <feGaussianBlur stdDeviation="12" result="blur" />
      <feComposite in="SourceGraphic" in2="blur" operator="over" />
    </filter>
  </defs>

  <!-- Base Badge with Neon Border -->
  <rect x="24" y="24" width="464" height="464" rx="110" fill="url(#bgGrad)" stroke="#DFFF2F" stroke-width="12" />

  <!-- Grid Glow Accent Lines -->
  <path d="M 120,380 L 190,310 L 260,340 L 390,170" fill="none" stroke="#00F0FF" stroke-width="12" stroke-linecap="round" stroke-linejoin="round" opacity="0.3" />

  <!-- Upward Growth Arrow + Stylized T/S Lettermark -->
  <!-- Ascending Bar Chart Pillars -->
  <rect x="110" y="310" width="44" height="90" rx="12" fill="#00F0FF" opacity="0.85" />
  <rect x="180" y="250" width="44" height="150" rx="12" fill="url(#arrowGrad)" opacity="0.95" />
  <rect x="250" y="190" width="44" height="210" rx="12" fill="url(#neonGrad)" />

  <!-- Dynamic Trendline Arrow Header -->
  <path d="M 110,330 L 190,260 L 260,290 L 380,140" fill="none" stroke="url(#neonGrad)" stroke-width="28" stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)" />

  <!-- Arrowhead -->
  <path d="M 320,140 L 395,135 L 390,210 Z" fill="#DFFF2F" stroke="#DFFF2F" stroke-width="6" stroke-linejoin="round" />
</svg>
